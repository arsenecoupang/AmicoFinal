# Supabase Configuration
REACT_APP_SUPABASE_URL=your_supabase_project_url
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Sentry Configuration (에러 추적)
REACT_APP_SENTRY_DSN=your_sentry_dsn_url

# Analytics Configuration
# SimpleAnalytics는 자동으로 도메인 감지하므로 추가 설정 불필요

# Performance Monitoring
REACT_APP_NEW_RELIC_LICENSE_KEY=your_new_relic_license_key
REACT_APP_NEW_RELIC_APP_ID=your_new_relic_app_id

# 배포 환경
REACT_APP_ENVIRONMENT=production
